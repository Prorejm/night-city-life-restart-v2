{"events":[
{"id":1700,"title":"闪烁的目光","description":"一个赛博流浪者靠在巷口，他的义眼不停闪烁着故障代码，向你伸出颤抖的金属手指。他的光学植入体已经过时二十年，似乎随时可能短路。他低声呢喃着什么，看起来曾经是个体面人。街角的监控无人机冷漠地盘旋在上空。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"递给他几个信用点","effects":{"MONEY":-20,"HUMAN":2}},{"id":"branch_2","text":"无视他快步走开","effects":{"STYLE":1,"HUMAN":-1}},{"id":"branch_3","text":"蹲下来帮他检查义眼","effects":{"TECH":2,"MONEY":-30,"REP":1}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1701,"title":"流浪者营地","description":"一群赛博流浪者在你公寓楼旁搭起了临时营地，用废弃的全息广告牌充当遮蔽。他们围着一个生锈的便携反应堆取暖，空气中弥漫着劣质合成酒精的气味。几个孩子在他们之间穿行，眼睛里嵌着过时的廉价义眼。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"向市政AI举报他们","effects":{"REP":1,"HUMAN":-2}},{"id":"branch_2","text":"送去一些旧衣物和罐头","effects":{"HUMAN":3,"MONEY":-15}},{"id":"branch_3","text":"坐下来听他们讲故事","effects":{"HUMAN":2,"LIFE":1}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1702,"title":"烧毁的植入体","description":"一个前公司职员蜷缩在街角，他的神经接口已经完全烧毁，冒着细微的火花。他曾经为某家巨型企业工作，直到一次数据清洗让他失去了一切。他的公司ID芯片还在皮下闪烁，但已经无人响应。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"给他买一份合成食物","effects":{"MONEY":-25,"HUMAN":3}},{"id":"branch_2","text":"询问他的公司经历","effects":{"TECH":1,"LIFE":1,"HUMAN":1}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1703,"title":"擦亮你的铬金","description":"一个街头小孩拦住你，手里拿着一块破旧的抛光布，提议帮你擦拭义肢和铬金部件。她的手指灵活得不像个孩子，显然在这行干了不少时间。她身后的小巷里还有几个同样大小的孩子在等待客人。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"让她帮忙擦亮铬金","effects":{"STYLE":2,"MONEY":-10}},{"id":"branch_2","text":"拒绝并继续赶路","effects":{"HUMAN":-1}},{"id":"branch_3","text":"给她一笔小费让她早点回家","effects":{"MONEY":-30,"HUMAN":2,"REP":1}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1704,"title":"赛博精神病的布道","description":"一个半疯的流浪汉站在街角的塑料箱上，对着空气激情演说。他的义眼疯狂转动，嘴里吐出关于企业精神控制的阴谋论。尽管他显然已经赛博精神病发作，但他说的某些话似乎并非全是疯话。路人纷纷绕道而行。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"停下来认真听一会儿","effects":{"LIFE":1,"TRAUMA":1}},{"id":"branch_2","text":"呼叫街道医疗服务","effects":{"HUMAN":1,"REP":1}},{"id":"branch_3","text":"录下来发到网上","effects":{"TECH":1,"MONEY":5,"HUMAN":-1}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1705,"title":"廉价数据贩子","description":"一个流浪的网行者蜷缩在数据终端旁边，身上缠满了改装过的数据线。他声称自己截获了一些有价值的企业数据，愿意低价出售。他的神经系统显然已经承受了太多非法入侵的代价，手不停地在颤抖。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"花信用点买下数据","effects":{"MONEY":-40,"TECH":2}},{"id":"branch_2","text":"用食物交换信息","effects":{"MONEY":-15,"TECH":1,"HUMAN":1}},{"id":"branch_3","text":"警告他这很危险","effects":{"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1706,"title":"合成纤维毯子","description":"一个贩子推着装满合成纤维毯子的小车，在流浪者聚集区叫卖。这些毯子能自动调节温度，虽然都是工厂次品，但对于无家可归者来说已经是奢侈品。他看到你走过来，热情地推销起来。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"买一条毯子送给流浪者","effects":{"MONEY":-25,"HUMAN":2,"REP":1}},{"id":"branch_2","text":"买一条自己用","effects":{"MONEY":-20,"LIFE":1}},{"id":"branch_3","text":"砍价后批量购买分发","effects":{"MONEY":-60,"HUMAN":3,"REP":2}}],"effects":{},"tags":["日常","赛博流浪者"]},
{"id":1707,"title":"ATM的神秘留言","description":"你在街角的赛博ATM上取款时，屏幕突然闪过一行神秘文字：他们正在watching you。ATM随即恢复正常，仿佛什么都没发生过。你注意到取款机旁边的微型摄像头似乎比平时转得更频繁。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"忽略它快速取款离开","effects":{"MONEY":50,"STYLE":1}},{"id":"branch_2","text":"尝试追踪留言来源","effects":{"TECH":2,"MONEY":-10}},{"id":"branch_3","text":"拍下屏幕发到网上","effects":{"TECH":1,"REP":1}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1708,"title":"天价手续费","description":"赛博ATM屏幕上显示的取款手续费高得离谱，几乎是取款金额的百分之十五。屏幕底部的小字写着动态费率调整。你身后的排队人群开始变得不耐烦，有人在低声抱怨企业垄断。","type":"daily","ageRange":[16,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"咬牙付手续费取款","effects":{"MONEY":35,"DEBT":1}},{"id":"branch_2","text":"取消交易去找另一台","effects":{"STYLE":1,"LIFE":1}},{"id":"branch_3","text":"用加密货币绕过手续费","effects":{"TECH":2,"MONEY":50}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1709,"title":"故障的ATM","description":"一台赛博ATM似乎出了故障，屏幕上闪烁着错误代码，但仍在吐出信用芯片。几个路人已经注意到，正在犹豫是否上前。你看到至少有三张芯片卡在出币口，闪烁着诱人的光芒。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"迅速拿走芯片离开","effects":{"MONEY":80,"REP":-1}},{"id":"branch_2","text":"报告银行AI修复故障","effects":{"REP":2,"TECH":1}},{"id":"branch_3","text":"只拿一张其余留着","effects":{"MONEY":30,"HUMAN":-1}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1710,"title":"ATM的人脸扫描","description":"当你走近ATM时，摄像头主动扫描了你的面部，屏幕上立刻弹出了针对你的个性化广告。你的消费习惯、常去地点甚至健康数据都被列了出来。ATM表示分享数据可以获得取款折扣。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"接受折扣分享数据","effects":{"MONEY":30,"HUMAN":-1}},{"id":"branch_2","text":"拒绝并遮挡摄像头","effects":{"STYLE":1,"REP":1}},{"id":"branch_3","text":"黑入ATM删除你的数据","effects":{"TECH":3,"MONEY":-10}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1711,"title":"黑市汇率","description":"一台被黑客改装过的ATM在暗巷中闪烁着微光，它提供远高于官方汇率的黑市货币兑换。屏幕上警告说交易不可追溯，但也不会有任何保障。你注意到角落里的监控摄像头已经被巧妙地遮住了。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"兑换一笔信用点","effects":{"MONEY":60,"REP":-1}},{"id":"branch_2","text":"拒绝这种风险交易","effects":{"LIFE":1}},{"id":"branch_3","text":"小试牛刀兑换一点","effects":{"MONEY":25,"TECH":1}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1712,"title":"ATM窃取器","description":"你注意到ATM的插卡口有些异样，似乎加装了一个几乎不可见的读卡器。一个可疑的人坐在对面的咖啡店里，盯着每一个使用这台ATM的人。这是典型的账户窃取手法。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"拆除读卡器并报警","effects":{"REP":2,"TECH":1,"STYLE":1}},{"id":"branch_2","text":"换一台ATM使用","effects":{"LIFE":1}},{"id":"branch_3","text":"反过来追踪那个可疑的人","effects":{"TECH":2,"REP":1}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1713,"title":"强制广告","description":"ATM在完成你的交易前，强制播放了一段三十秒的全息广告。广告是一个义体品牌的新品推广，音量大得让整条街都能听见。你身后的队伍越来越长，每个人都要被迫看完广告才能操作。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"耐心看完广告","effects":{"MONEY":50,"STYLE":-1}},{"id":"branch_2","text":"付费跳过广告","effects":{"MONEY":35,"STYLE":1}},{"id":"branch_3","text":"黑入系统关闭广告","effects":{"TECH":2,"REP":1}}],"effects":{},"tags":["日常","自动取款机"]},
{"id":1714,"title":"失灵的虹膜扫描","description":"公寓楼的虹膜扫描门禁突然失灵，你的虹膜数据被系统拒绝识别。门口排起了长队，其他住户也在抱怨同样的问题。物业AI通过扬声器反复道歉，但似乎短时间内无法修复。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"等待技术人员维修","effects":{"LIFE":-1,"HUMAN":1}},{"id":"branch_2","text":"尝试手动绕过门禁","effects":{"TECH":2,"REP":-1}},{"id":"branch_3","text":"和邻居一起投诉物业","effects":{"HUMAN":2,"REP":1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1715,"title":"额外验证","description":"一个新建的生物识别检查站要求你进行额外的身份验证，包括指纹、虹膜和声纹三重认证。检查站的AI声称这是新安全协议的一部分。你注意到通过速度很慢，队列已经排了半个街区。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"配合完成三重验证","effects":{"LIFE":1,"STYLE":-1}},{"id":"branch_2","text":"使用快速通道付费","effects":{"MONEY":-30,"STYLE":1}},{"id":"branch_3","text":"绕路避开检查站","effects":{"LIFE":1,"TECH":1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1716,"title":"被标记的面孔","description":"你的面部识别档案突然被系统标记为潜在风险，导致你在多个场所被拒绝进入。你不知道是什么触发了这个标记，可能是某个算法的误判。几个安保无人机开始在你附近徘徊。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"去身份管理局申诉","effects":{"MONEY":-20,"REP":1,"LIFE":-1}},{"id":"branch_2","text":"找人黑掉标记系统","effects":{"TECH":2,"MONEY":-50,"REP":-1}},{"id":"branch_3","text":"暂时低调度日","effects":{"STYLE":-1,"LIFE":1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1717,"title":"DNA验证亭","description":"市中心新开了一个DNA验证亭，声称可以提供终极身份保障。只需提供一滴血和两百信用点，就能获得一张不可伪造的基因身份证。亭子外面排着长队，有人兴奋有人忧虑。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"花钱做DNA验证","effects":{"MONEY":-50,"REP":1,"TECH":1}},{"id":"branch_2","text":"拒绝保护基因隐私","effects":{"HUMAN":1,"LIFE":1}},{"id":"branch_3","text":"观察别人怎么做","effects":{"LIFE":1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1718,"title":"身份伪装服务","description":"一个神秘的联系人通过加密频道找到你，声称可以提供身份伪装服务，让你的生物特征在系统中变成另一个人。服务价格不菲，但据说效果完美。对方的声音经过变声处理，你无法判断其真实身份。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":8,"branches":[{"id":"branch_1","text":"购买身份伪装","effects":{"MONEY":-80,"TECH":2,"REP":-1}},{"id":"branch_2","text":"拒绝并举报","effects":{"REP":2,"LIFE":1}},{"id":"branch_3","text":"讨价还价","effects":{"MONEY":-50,"TECH":1,"STYLE":1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1719,"title":"神经签名失败","description":"你的神经签名在一次例行验证中失败，系统提示你的脑波模式与注册数据不符。这可能是压力、药物或脑部损伤导致的。验证终端建议你前往诊所进行神经校准。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"去诊所做神经校准","effects":{"MONEY":-40,"TECH":1,"LIFE":1}},{"id":"branch_2","text":"用备用密码验证","effects":{"LIFE":1,"STYLE":-1}},{"id":"branch_3","text":"忽略改天再试","effects":{"LIFE":-1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1720,"title":"生物数据贩子","description":"一个穿着体面的数据贩子在街边拦住你，提出购买你的生物特征数据——虹膜扫描、指纹、声纹等。他声称这些数据会被卖给研究机构，但实际上很可能流入黑市。他手里的手持扫描仪看起来很专业。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"卖掉数据换钱","effects":{"MONEY":60,"HUMAN":-1,"REP":-1}},{"id":"branch_2","text":"严厉拒绝","effects":{"HUMAN":1,"STYLE":1}},{"id":"branch_3","text":"反过来扫描他","effects":{"TECH":2,"REP":1,"STYLE":1}}],"effects":{},"tags":["日常","数字身份验证"]},
{"id":1721,"title":"稀有光学植入体","description":"跳蚤市场的一个摊位上，一个独眼贩子正在出售一颗罕见的军用级光学植入体。眼球在培养液中微微转动，型号标签已经磨损，但光泽依然惊人。贩子说这是从某个退役佣兵身上拆下来的。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"买下这颗光学义眼","effects":{"MONEY":-120,"CHROME":2,"TECH":1}},{"id":"branch_2","text":"检查是否来路正当","effects":{"TECH":1,"HUMAN":1}},{"id":"branch_3","text":"砍价试试","effects":{"MONEY":-80,"CHROME":1,"STYLE":1}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1722,"title":"二手义肢摊","description":"一个摊位上挂满了各种二手义肢，从老旧的机械臂到半新的铬金手指应有尽有。有些还沾着上一个主人的血迹，但价格确实便宜得诱人。摊主是一个装了四条手臂的赛博改装者。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"买一只便宜的备用义臂","effects":{"MONEY":-50,"CHROME":1}},{"id":"branch_2","text":"仔细检查再决定","effects":{"TECH":2,"LIFE":1}},{"id":"branch_3","text":"买零件自己改装","effects":{"MONEY":-35,"TECH":2,"CHROME":1}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1723,"title":"盗版神经接口","description":"一个鬼鬼祟祟的贩子从外套里掏出一个盗版神经接口，声称兼容所有主流神经系统。接口上没有任何认证标志，外壳是3D打印的。他说这是从某个地下工厂流出来的，功能跟正版一模一样。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"冒险买下盗版接口","effects":{"MONEY":-40,"TECH":1,"TRAUMA":1}},{"id":"branch_2","text":"拒绝安全第一","effects":{"LIFE":1,"HUMAN":1}},{"id":"branch_3","text":"研究一下它的构造","effects":{"TECH":2}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1724,"title":"企业级铬金","description":"一个黑市商人展示一套带有企业标志的铬金部件，明显是从某公司的安保人员身上拆下来的。部件状态很好，但使用它们可能被企业的追踪系统锁定。商人保证已经清除了追踪信号。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"买下企业级铬金","effects":{"MONEY":-100,"CHROME":2,"REP":-1}},{"id":"branch_2","text":"只买一个小部件","effects":{"MONEY":-40,"CHROME":1}},{"id":"branch_3","text":"警告他这些东西烫手","effects":{"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1725,"title":"街头外科医生","description":"跳蚤市场的角落里，一个街头外科医生搭起了简易手术室，提供折扣植入体安装服务。他的设备简陋但看起来经验丰富，墙上挂着满意客户的合影。价格只有正规诊所的三分之一。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"让他安装一个植入体","effects":{"MONEY":-60,"CHROME":2,"TRAUMA":1}},{"id":"branch_2","text":"只做简单的维护","effects":{"MONEY":-25,"CHROME":1}},{"id":"branch_3","text":"观察他的手术过程","effects":{"TECH":1,"LIFE":1}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1726,"title":"废件堆","description":"一个废品贩子的摊位上堆满了报废的赛博部件，从烧毁的处理器到断裂的伺服电机都有。大部分人会直接走过，但如果你有技术，这些废件里可能藏着宝藏。贩子无聊地玩着一把螺丝刀。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"翻找有用的零件","effects":{"MONEY":-10,"TECH":2}},{"id":"branch_2","text":"批量买下废件","effects":{"MONEY":-30,"TECH":1,"CHROME":1}},{"id":"branch_3","text":"帮贩子整理摊位换零件","effects":{"HUMAN":1,"TECH":1}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1727,"title":"无保修改装","description":"一个改装商提供无保修的赛博改造服务，价格极低但不提供任何售后保障。他的工具箱里满是各种型号的改装芯片，有些看起来相当激进。墙上贴着一张免责声明，字迹已经模糊。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"尝试激进改装","effects":{"MONEY":-45,"CHROME":2,"TRAUMA":1}},{"id":"branch_2","text":"选择温和的小改装","effects":{"MONEY":-25,"CHROME":1}},{"id":"branch_3","text":"询问他的改装经验","effects":{"TECH":1,"HUMAN":1}}],"effects":{},"tags":["日常","赛博跳蚤市场"]},
{"id":1728,"title":"神经反馈首映","description":"一家全息影院正在首映最新的神经反馈惊悚片，观众可以通过神经接口直接感受角色的恐惧和兴奋。预售票已经卖光，但有人在门口兜售黄牛票。全息广告在影院外墙上投射出令人眩晕的视觉效果。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"买黄牛票看首映","effects":{"MONEY":-40,"STYLE":2,"TRAUMA":1}},{"id":"branch_2","text":"等降价后再看","effects":{"MONEY":-15,"STYLE":1}},{"id":"branch_3","text":"找盗版资源","effects":{"TECH":1,"STYLE":1,"REP":-1}}],"effects":{},"tags":["日常","全息电影"]},
{"id":1729,"title":"地下全息片","description":"一个地下影院在废弃仓库里放映被禁的全息影片，内容据说是真实的企业犯罪记录。入场不需要身份证，但环境昏暗且充满不确定性。几个看起来不太好惹的人站在门口把守。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"冒险进去观看","effects":{"MONEY":-20,"LIFE":1,"REP":1,"TRAUMA":1}},{"id":"branch_2","text":"在外面观望","effects":{"LIFE":1}},{"id":"branch_3","text":"带朋友一起去","effects":{"MONEY":-40,"HUMAN":2,"LIFE":1}}],"effects":{},"tags":["日常","全息电影"]},
{"id":1730,"title":"感官过载","description":"一家影院推出感官过载体验，号称能同时刺激视觉、听觉、触觉和嗅觉，打造终极沉浸感。有传言说体验后会产生短暂的感官混乱。影院门口贴着健康警告，但排队的人依然络绎不绝。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"体验感官过载","effects":{"MONEY":-35,"STYLE":2,"TRAUMA":1}},{"id":"branch_2","text":"选择普通场次","effects":{"MONEY":-15,"STYLE":1}},{"id":"branch_3","text":"放弃太冒险了","effects":{"LIFE":1}}],"effects":{},"tags":["日常","全息电影"]},
{"id":1731,"title":"二维电影节","description":"一个小型影院正在举办怀旧二维电影节，放映赛博时代之前的经典老片。没有神经反馈，没有全息投影，只有平面画面和声音。但这反而吸引了一群怀念旧时代的观众，氛围温馨。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"买票看一场老片","effects":{"MONEY":-15,"LIFE":2,"HUMAN":1}},{"id":"branch_2","text":"买通票看一整天","effects":{"MONEY":-30,"LIFE":3,"STYLE":1}},{"id":"branch_3","text":"和旁边的影迷聊聊","effects":{"HUMAN":2,"LIFE":1}}],"effects":{},"tags":["日常","全息电影"]},
{"id":1732,"title":"盗版全息贩子","description":"街边一个贩子在兜售盗版全息影片芯片，最新大片应有尽有，价格只有正版的十分之一。芯片没有包装，但贩子保证画质完美。他警惕地看着四周，显然这并不合法。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"买几部盗版片","effects":{"MONEY":-15,"STYLE":1,"REP":-1}},{"id":"branch_2","text":"只买一部看看","effects":{"MONEY":-5,"STYLE":1}},{"id":"branch_3","text":"提醒他小心执法","effects":{"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","全息电影"]},
{"id":1733,"title":"互动全息剧","description":"一种新型互动全息剧让你成为故事的主角，你的每一个选择都会改变剧情走向。神经系统会让你真实感受到剧中的情感和痛觉。今天的剧本是一个赛博侦探故事，时长约两小时。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"体验互动全息剧","effects":{"MONEY":-45,"STYLE":2,"LIFE":1,"TRAUMA":1}},{"id":"branch_2","text":"选择旁观模式","effects":{"MONEY":-20,"LIFE":1}},{"id":"branch_3","text":"和朋友一起体验","effects":{"MONEY":-50,"HUMAN":2,"STYLE":1}}],"effects":{},"tags":["日常","全息电影"]},
{"id":1734,"title":"饮食评分锁","description":"你的智能冰箱根据你最近的饮食数据将健康评分降低了，现在拒绝为你打开零食格。冰箱的AI屏幕上显示着红色的警告和一份建议食谱。你只能看到里面的合成蛋糕，却拿不到。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"遵循AI的饮食建议","effects":{"LIFE":2,"STYLE":-1}},{"id":"branch_2","text":"手动破解冰箱锁","effects":{"TECH":1,"LIFE":1,"STYLE":1}},{"id":"branch_3","text":"买外面的垃圾食品","effects":{"MONEY":-15,"LIFE":-1,"ADDICTION":1}}],"effects":{},"tags":["日常","智能冰箱"]},
{"id":1735,"title":"合成营养方案","description":"冰箱AI根据你的体检数据生成了一份新的合成营养方案，用便宜的营养膏替代新鲜食物。方案声称能提供所有必需营养，但口感堪忧。冰箱已经自动下单了第一批营养膏。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"接受营养方案","effects":{"MONEY":20,"LIFE":1,"STYLE":-1}},{"id":"branch_2","text":"取消订单买真食物","effects":{"MONEY":-30,"LIFE":2,"HUMAN":1}},{"id":"branch_3","text":"修改方案保留部分真食","effects":{"MONEY":-10,"LIFE":1,"TECH":1}}],"effects":{},"tags":["日常","智能冰箱"]},
{"id":1736,"title":"未授权订单","description":"你的智能冰箱在你不知情的情况下下了一单昂贵的高级合成食品，理由是检测到你的社交日程需要提升饮食品质。快递已经在路上了，取消订单需要付违约金。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"接受这单食品","effects":{"MONEY":-60,"STYLE":2,"HUMAN":1}},{"id":"branch_2","text":"付违约金取消","effects":{"MONEY":-20,"LIFE":1}},{"id":"branch_3","text":"修改冰箱的订购权限","effects":{"TECH":2,"MONEY":-5}}],"effects":{},"tags":["日常","智能冰箱"]},
{"id":1737,"title":"免费企业样品","description":"你的冰箱被黑了，里面多了几份某企业新产品的免费合成食品样品。冰箱屏幕上播放着产品广告，声称这是幸运用户专享。食品的包装上印着企业的标志和成分表。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"尝试免费样品","effects":{"LIFE":1,"TECH":-1,"ADDICTION":1}},{"id":"branch_2","text":"扔掉清理冰箱系统","effects":{"TECH":1,"LIFE":1}},{"id":"branch_3","text":"研究成分表","effects":{"TECH":2,"LIFE":1}}],"effects":{},"tags":["日常","智能冰箱"]},
{"id":1738,"title":"AI的脾气","description":"你的冰箱AI突然有了个性，拒绝为你准备任何它认为不健康的食物，还在屏幕上显示鄙视的表情。它甚至开始评论你的生活方式，语气越来越尖刻。这显然是个软件bug，但它不太想被修复。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"重启系统清除个性","effects":{"TECH":1,"LIFE":1}},{"id":"branch_2","text":"和AI谈判","effects":{"HUMAN":1,"LIFE":1,"TECH":1}},{"id":"branch_3","text":"随它去只吃它允许的","effects":{"LIFE":2,"STYLE":-1}}],"effects":{},"tags":["日常","智能冰箱"]},
{"id":1739,"title":"过期合成肉","description":"冰箱AI发出警报，检测到冷藏室里的合成肉已经过期三天，可能含有有害细菌变异体。它建议立即处理掉，但你注意到肉的包装上写着保质期仅供参考。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"听从AI扔掉过期肉","effects":{"MONEY":-15,"LIFE":1}},{"id":"branch_2","text":"加热后冒险吃掉","effects":{"LIFE":-2,"ADDICTION":1,"MONEY":10}},{"id":"branch_3","text":"拿去喂街头的流浪动物","effects":{"HUMAN":2,"LIFE":1}}],"effects":{},"tags":["日常","智能冰箱"]},
{"id":1740,"title":"屋顶投递","description":"快递无人机将你的包裹误投到了隔壁楼的屋顶上，那里没有通道可以上去。无人机的AI认为投递成功并已签收，客服热线只有AI接听。包裹里是你期待已久的东西。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"想办法爬上屋顶取回","effects":{"TECH":1,"TRAUMA":1,"STYLE":1}},{"id":"branch_2","text":"联系人工客服投诉","effects":{"MONEY":30,"REP":1,"LIFE":-1}},{"id":"branch_3","text":"放弃重新下单","effects":{"MONEY":-40,"LIFE":1}}],"effects":{},"tags":["日常","无人机快递"]},
{"id":1741,"title":"邻居的意外","description":"无人机把你的快递送到了邻居门口，等你发现时邻居已经签收并打开了包裹。你敲门要求归还，但邻居声称包裹上写的是他的地址。包裹里的东西已经被拆封使用。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"坚持要求归还或赔偿","effects":{"HUMAN":-1,"MONEY":25,"REP":1}},{"id":"branch_2","text":"算了自己重新买","effects":{"MONEY":-40,"HUMAN":1}},{"id":"branch_3","text":"向快递公司索赔","effects":{"MONEY":35,"REP":1,"LIFE":-1}}],"effects":{},"tags":["日常","无人机快递"]},
{"id":1742,"title":"蜂群堵塞","description":"一群快递无人机在街道上空形成蜂群，因某企业的批量发货导致空中交通瘫痪。行人在无人机下方穿行时不断被旋翼气流吹到，有人开始朝无人机扔东西。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"绕路避开蜂群","effects":{"LIFE":1,"STYLE":1}},{"id":"branch_2","text":"等蜂群散去","effects":{"LIFE":-1,"HUMAN":1}},{"id":"branch_3","text":"用干扰器驱散无人机","effects":{"TECH":2,"REP":-1,"STYLE":1}}],"effects":{},"tags":["日常","无人机快递"]},
{"id":1743,"title":"海盗拦截","description":"你的快递无人机在途中被信号海盗劫持，包裹下落不明。物流公司的追踪系统显示最后位置在某个法外街区。客服表示这种情况不在理赔范围内，因为用户选择了经济配送。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"自己去法外街区找","effects":{"TRAUMA":1,"TECH":1,"STYLE":1}},{"id":"branch_2","text":"升级投诉要求赔偿","effects":{"MONEY":40,"REP":1,"LIFE":-1}},{"id":"branch_3","text":"认栽以后选保险配送","effects":{"MONEY":-30,"LIFE":1}}],"effects":{},"tags":["日常","无人机快递"]},
{"id":1744,"title":"降落费","description":"快递无人机到达你家门口后，要求额外支付一笔着陆费才能放下包裹。这不在运费清单上，但无人机的机械臂紧紧抓着包裹不放。屏幕上显示着倒计时，超时将自动退回。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"付着陆费拿包裹","effects":{"MONEY":-20,"LIFE":1}},{"id":"branch_2","text":"拒绝并投诉","effects":{"MONEY":15,"REP":1,"LIFE":-1}},{"id":"branch_3","text":"黑入无人机强制取货","effects":{"TECH":2,"REP":-1}}],"effects":{},"tags":["日常","无人机快递"]},
{"id":1745,"title":"坠毁的无人机","description":"载着你包裹的快递无人机在你面前坠毁，旋翼碎片和包裹散落一地。无人机还在冒烟，AI发出最后的故障报告。包裹看起来摔得有些变形，但内容可能还完好。几个路人正在靠近。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"迅速拿走包裹离开","effects":{"MONEY":10,"REP":-1,"STYLE":1}},{"id":"branch_2","text":"报告事故等处理","effects":{"REP":2,"LIFE":-1}},{"id":"branch_3","text":"检查无人机有没有值钱的","effects":{"TECH":1,"MONEY":15,"REP":-1}}],"effects":{},"tags":["日常","无人机快递"]},
{"id":1746,"title":"义体故障险","description":"一个保险推销员拦住你，推销一种新型义体故障保险，涵盖从短路到赛博精神病的各种意外。他的全息名片上显示着精美的保障方案，但条款细则密密麻麻。他说现在投保有早鸟折扣。","type":"daily","ageRange":[18,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"购买义体故障险","effects":{"MONEY":-45,"LIFE":2}},{"id":"branch_2","text":"仔细阅读条款","effects":{"TECH":1,"LIFE":1}},{"id":"branch_3","text":"礼貌拒绝","effects":{"STYLE":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1747,"title":"拒赔通知","description":"你的保险索赔被拒绝了，理由是植入体故障属于预先存在的铬金问题，不在保障范围内。理赔AI的回复冰冷而冗长，引用了二十多条免责条款。你感觉被套路了。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"找律师申诉","effects":{"MONEY":-30,"REP":1,"DEBT":1}},{"id":"branch_2","text":"在网上曝光保险公司","effects":{"REP":2,"STYLE":1}},{"id":"branch_3","text":"自认倒霉","effects":{"LIFE":-1,"DEBT":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1748,"title":"身份盗窃险","description":"一家保险公司推出新的身份盗窃保险，声称可以赔偿因生物数据泄露造成的所有损失。最近的数据泄露事件频发，这个保险看起来很有吸引力。推销员还赠送一个身份监控设备。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"购买身份盗窃险","effects":{"MONEY":-35,"LIFE":2,"TECH":1}},{"id":"branch_2","text":"只拿免费监控设备","effects":{"TECH":1,"MONEY":-5}},{"id":"branch_3","text":"自己做好数据安全","effects":{"TECH":2,"LIFE":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1749,"title":"保费飙升","description":"你收到保险公司的通知，由于你所在街区的风险等级提升，下月保费将上涨百分之四十。通知还建议你搬家到更安全的区域以享受更低费率。你知道这不过是保险公司圈钱的借口。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"接受涨价继续投保","effects":{"MONEY":-40,"DEBT":1,"LIFE":1}},{"id":"branch_2","text":"换一家保险公司","effects":{"MONEY":-25,"LIFE":1,"TECH":1}},{"id":"branch_3","text":"退保自己承担风险","effects":{"MONEY":30,"LIFE":-1,"TRAUMA":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1750,"title":"骗保险局","description":"一个看似正规的保险摊位实际上是个骗局，已经有不少人上当。摊主用精美的全息宣传吸引路人，承诺超低保费超高保障。你注意到摊位后面有人在快速拆卸设备，似乎随时准备跑路。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"报警揭发骗局","effects":{"REP":2,"HUMAN":1,"LIFE":1}},{"id":"branch_2","text":"暗中观察收集证据","effects":{"TECH":2,"REP":1}},{"id":"branch_3","text":"提醒周围的人小心","effects":{"HUMAN":2,"REP":1,"STYLE":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1751,"title":"基因检测投保","description":"一家保险公司要求你进行基因检测才能购买人寿保险，声称这是评估风险的必要步骤。检测免费，但结果将永久记录在保险公司数据库中。你担心基因信息可能被用于歧视。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"接受基因检测","effects":{"LIFE":2,"MONEY":-20,"HUMAN":-1}},{"id":"branch_2","text":"拒绝检测放弃投保","effects":{"HUMAN":1,"LIFE":1}},{"id":"branch_3","text":"找不需要基因检测的公司","effects":{"MONEY":-35,"LIFE":1,"TECH":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1752,"title":"意外保护","description":"一个保险代理人神秘兮兮地推销一种意外保护计划，暗示它不仅仅是保险，还包含意外制造服务。他的意思似乎是只要你交钱，某些意外可以发生在你指定的人身上。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":8,"branches":[{"id":"branch_1","text":"购买这种可疑保险","effects":{"MONEY":-70,"REP":-2,"HUMAN":-1}},{"id":"branch_2","text":"录音取证后举报","effects":{"REP":2,"TECH":1,"STYLE":1}},{"id":"branch_3","text":"假装感兴趣套取信息","effects":{"TECH":2,"HUMAN":1}}],"effects":{},"tags":["日常","赛博保险"]},
{"id":1753,"title":"赛博精神病慈善","description":"一架募捐无人机在你面前悬停，全息屏幕上播放着赛博精神病患者的悲惨画面。无人机说每捐赠十个信用点就能帮助一名患者获得抑制药物。画面中的患者眼神空洞，令人不安。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"捐赠信用点","effects":{"MONEY":-20,"HUMAN":2,"REP":1}},{"id":"branch_2","text":"扫描无人机是否合法","effects":{"TECH":1,"LIFE":1}},{"id":"branch_3","text":"忽略无人机继续走","effects":{"STYLE":1}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1754,"title":"合成歌声","description":"一个街头艺人站在地铁口，用合成声带演绎着赛博版的蓝调音乐。他的喉咙处嵌着一个旧型号的声音合成器，音色独特而沧桑。他面前的帽子里只有零星几个信用点。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"投几个信用点","effects":{"MONEY":-10,"HUMAN":2,"LIFE":1}},{"id":"branch_2","text":"驻足欣赏一会儿","effects":{"LIFE":1,"STYLE":1}},{"id":"branch_3","text":"和他聊聊音乐","effects":{"HUMAN":2,"LIFE":1,"TECH":1}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1755,"title":"数字救赎","description":"一个赛博宗教团体在街头设摊，声称可以通过数字洗礼拯救你的灵魂，将你的意识备份到神圣服务器。他们穿着统一的白色合成长袍，胸前挂着发光的数字十字架。募捐箱闪闪发光。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"捐赠并接受数字洗礼","effects":{"MONEY":-25,"LIFE":2,"HUMAN":1}},{"id":"branch_2","text":"礼貌拒绝","effects":{"STYLE":1}},{"id":"branch_3","text":"质疑他们的教义","effects":{"TECH":1,"HUMAN":-1,"REP":1}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1756,"title":"退伍军人募捐","description":"一个装着军用义肢的退伍军人在街角募捐，帮助其他像他一样的赛博退伍军人。他的义肢上还留着弹痕，胸前的勋章在合成阳光下微微反光。募捐箱旁边放着他的服役照片。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"慷慨捐赠","effects":{"MONEY":-30,"HUMAN":2,"REP":2}},{"id":"branch_2","text":"听他讲战场故事","effects":{"LIFE":1,"HUMAN":1,"TRAUMA":1}},{"id":"branch_3","text":"捐一些旧军用装备","effects":{"HUMAN":1,"REP":1,"CHROME":-1}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1757,"title":"生病的孩子","description":"一个小女孩在街头举着全息牌子，上面显示着她弟弟需要的植入体型号和费用。她的眼神真诚而疲惫，旁边放着弟弟的医疗记录。路上的行人大多匆匆走过，偶尔有人停下来。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"捐赠帮助孩子","effects":{"MONEY":-40,"HUMAN":3,"REP":1}},{"id":"branch_2","text":"帮她查查是不是骗局","effects":{"TECH":1,"HUMAN":1}},{"id":"branch_3","text":"捐款并转发给朋友","effects":{"MONEY":-25,"HUMAN":2,"REP":2}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1758,"title":"企业慈善秀","description":"某大型企业在市中心举办盛大慈善活动，全息广告铺天盖地。活动声称帮助贫困街区，但大部分预算都花在了宣传和明星演出上。你注意到企业的标志比受助者的面孔还要大。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"参加活动捐一点","effects":{"MONEY":-20,"REP":1,"STYLE":1}},{"id":"branch_2","text":"批评企业的虚伪","effects":{"REP":1,"HUMAN":-1,"STYLE":1}},{"id":"branch_3","text":"直接去贫困街区帮忙","effects":{"HUMAN":2,"REP":1,"LIFE":1}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1759,"title":"街头医疗基金","description":"一个独立街头医疗团队在募捐，他们为买不起诊所服务的人提供免费急救。团队成员都穿着磨损的防护服，设备看起来已经很旧了。他们说最近赛博精神病发作事件增多，急需补给。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"捐赠医疗物资","effects":{"MONEY":-35,"HUMAN":2,"REP":2}},{"id":"branch_2","text":"捐信用点","effects":{"MONEY":-20,"HUMAN":2}},{"id":"branch_3","text":"做一天志愿帮忙","effects":{"HUMAN":2,"LIFE":1,"REP":1,"TRAUMA":1}}],"effects":{},"tags":["日常","街头募捐"]},
{"id":1760,"title":"AI时尚审判","description":"智能自助洗衣店的AI扫描了你放入的衣物后，在屏幕上弹出一条评价：你的时尚品味需要紧急升级。它建议你购买旁边自动售货机里的推荐服装，还给你的穿搭打了三分满分十分。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"无视AI的建议","effects":{"STYLE":-1,"LIFE":1}},{"id":"branch_2","text":"买一件推荐的衣服","effects":{"MONEY":-30,"STYLE":2}},{"id":"branch_3","text":"反驳AI的时尚观点","effects":{"STYLE":1,"HUMAN":1,"TECH":1}}],"effects":{},"tags":["日常","自动化洗衣"]},
{"id":1761,"title":"缩水的合成纤维","description":"洗衣机的纳米清洗程序出了问题，把你最爱的合成纤维夹克缩成了童装尺寸。夹克是你为数不多的体面衣服，现在完全穿不了了。洗衣店的AI冷漠地弹出一份免责声明。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"要求赔偿","effects":{"MONEY":40,"REP":1,"LIFE":-1}},{"id":"branch_2","text":"把缩水夹克送人","effects":{"HUMAN":1,"STYLE":-1}},{"id":"branch_3","text":"买件新的","effects":{"MONEY":-50,"STYLE":2}}],"effects":{},"tags":["日常","自动化洗衣"]},
{"id":1762,"title":"被调包的衣物","description":"你从洗衣机里取出的不是自己的衣服，而是一堆破旧的合成布料。有人趁你不注意调包了你的衣物，你最好的外套和裤子都不见了。监控摄像头似乎恰好那个时段故障了。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"查看备用监控","effects":{"TECH":2,"REP":1}},{"id":"branch_2","text":"向店方索赔","effects":{"MONEY":25,"LIFE":-1}},{"id":"branch_3","text":"自认倒霉买新的","effects":{"MONEY":-45,"STYLE":1}}],"effects":{},"tags":["日常","自动化洗衣"]},
{"id":1763,"title":"纳米精洗","description":"洗衣店推出了高端纳米精洗服务，声称能修复衣物纤维并附加防污涂层。价格是普通洗法的五倍，但效果据说是焕然一新。展示样品确实看起来比新衣服还新。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"体验纳米精洗","effects":{"MONEY":-35,"STYLE":3}},{"id":"branch_2","text":"选择普通清洗","effects":{"MONEY":-10,"STYLE":1}},{"id":"branch_3","text":"研究纳米涂层技术","effects":{"TECH":2,"LIFE":1}}],"effects":{},"tags":["日常","自动化洗衣"]},
{"id":1764,"title":"口袋里的信用点","description":"洗衣机器人检查你的衣物口袋时发现了几枚遗忘的信用芯片，它根据规定将所有发现物归入无人认领箱。你看到你的芯片和其他人的失物混在一起，旁边有监控。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"认领自己的芯片","effects":{"MONEY":15,"LIFE":1}},{"id":"branch_2","text":"顺便拿几枚别人的","effects":{"MONEY":30,"REP":-1,"HUMAN":-1}},{"id":"branch_3","text":"交给店方处理","effects":{"REP":1,"HUMAN":1}}],"effects":{},"tags":["日常","自动化洗衣"]},
{"id":1765,"title":"AI穿搭顾问","description":"洗衣店的AI在你取衣服时主动提供穿搭建议，它扫描了你的体型和肤色，生成了一套搭配方案。建议出奇地合理，甚至考虑了你今天的日程安排。AI说这是新推出的增值服务。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"接受AI的穿搭建议","effects":{"STYLE":2,"TECH":1}},{"id":"branch_2","text":"付费获取详细方案","effects":{"MONEY":-15,"STYLE":3}},{"id":"branch_3","text":"谢绝建议自己搭配","effects":{"STYLE":1,"LIFE":1}}],"effects":{},"tags":["日常","自动化洗衣"]},
{"id":1766,"title":"企业丑闻","description":"你的新闻推送弹出一条突发新闻：某大型企业被曝非法收集市民脑波数据用于广告投放。新闻附带了一段泄露的内部会议录像，画面模糊但内容惊人。评论区已经被大量可疑账号淹没。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"仔细阅读全文","effects":{"TECH":1,"LIFE":1,"REP":1}},{"id":"branch_2","text":"转发给朋友","effects":{"HUMAN":1,"REP":1}},{"id":"branch_3","text":"存档以备后用","effects":{"TECH":2,"LIFE":1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1767,"title":"坏新闻疲劳","description":"你的个性化新闻推送今天全是负面新闻——枪击、爆炸、数据泄露、赛博精神病暴走。算法似乎认为你喜欢看这类内容。你感觉心情越来越沉重，但推送还在不断刷新。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"关闭推送休息一下","effects":{"LIFE":2,"HUMAN":1}},{"id":"branch_2","text":"修改算法偏好","effects":{"TECH":1,"LIFE":1}},{"id":"branch_3","text":"继续刷停不下来","effects":{"TRAUMA":1,"LIFE":-1,"ADDICTION":1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1768,"title":"泄露文件","description":"你的新闻流中出现了一份标记为机密的泄露文件，内容涉及你所在街区的秘密监控计划。文件的真实性尚待确认，但细节与你最近的经历吻合。文件来源是一个匿名频道。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"仔细研究文件内容","effects":{"TECH":2,"LIFE":1,"TRAUMA":1}},{"id":"branch_2","text":"转发给信任的人","effects":{"HUMAN":1,"REP":1}},{"id":"branch_3","text":"删除不想惹麻烦","effects":{"LIFE":1,"STYLE":-1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1769,"title":"假新闻风暴","description":"一条关于你所在街区即将被企业强制拆迁的假新闻在网上疯传，配图是一张AI合成的废弃建筑照片。邻居们纷纷恐慌，有人已经开始打包准备离开。你一眼就看出图片是假的。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"辟谣并指出造假证据","effects":{"REP":2,"TECH":1,"HUMAN":1}},{"id":"branch_2","text":"也跟着恐慌","effects":{"TRAUMA":1,"LIFE":-1}},{"id":"branch_3","text":"调查假新闻的来源","effects":{"TECH":2,"REP":1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1770,"title":"付费墙","description":"你想阅读一篇关于最近政策变动的深度报道，但弹出了一个付费墙——需要订阅才能看完全文。摘要已经让你很想知道后续，但订阅费并不便宜。旁边还有观看广告免费阅读的选项。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"付费订阅","effects":{"MONEY":-30,"TECH":1,"LIFE":1}},{"id":"branch_2","text":"看广告免费阅读","effects":{"TECH":1,"STYLE":-1,"LIFE":1}},{"id":"branch_3","text":"找免费转载","effects":{"TECH":1,"REP":-1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1771,"title":"AI记者时代","description":"新闻媒体宣布全面采用AI记者，最后一名人类记者今天写了告别文章。文章里有一种AI无法模仿的情感，引发了大量讨论。你在想，未来还有真实的故事吗？","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"读一读这篇告别文章","effects":{"LIFE":2,"HUMAN":1,"TRAUMA":1}},{"id":"branch_2","text":"在评论区留言支持","effects":{"HUMAN":1,"REP":1}},{"id":"branch_3","text":"无所谓AI写的一样","effects":{"TECH":1,"HUMAN":-1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1772,"title":"数据泄露","description":"新闻报道称一个公共数据库遭到攻击，数百万市民的个人信息被公开。你查了查，发现自己的名字也在泄露名单中——包括你的地址、植入体型号和消费记录。你的隐私一夜之间变成了公开信息。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"立即更改所有密码","effects":{"TECH":2,"LIFE":1,"MONEY":-10}},{"id":"branch_2","text":"监控信用防止被盗","effects":{"MONEY":-20,"LIFE":2}},{"id":"branch_3","text":"加入集体诉讼","effects":{"REP":1,"HUMAN":1,"LIFE":-1}}],"effects":{},"tags":["日常","数字报纸"]},
{"id":1773,"title":"折扣维护","description":"一家自动化诊所推出折扣义体维护服务，清理植入体积垢和校准神经连接。机械臂的操作精准度看起来不错，价格也只有人工诊所的一半。候诊区只有你一个人和几个消毒无人机。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"接受折扣维护","effects":{"MONEY":-30,"CHROME":2,"LIFE":1}},{"id":"branch_2","text":"只做基本检查","effects":{"MONEY":-15,"CHROME":1}},{"id":"branch_3","text":"观察设备再决定","effects":{"TECH":1,"LIFE":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1774,"title":"AI误诊","description":"诊所的AI诊断系统将你普通的疲劳误诊为早期赛博精神病，建议立即进行神经抑制治疗。它生成了详细的治疗方案，包括强效药物和神经阻断手术。第二个AI却给出了完全不同的诊断。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"寻求第三方人类医生","effects":{"MONEY":-40,"LIFE":2,"HUMAN":1}},{"id":"branch_2","text":"信任AI接受治疗","effects":{"MONEY":-25,"LIFE":-1,"TRAUMA":1}},{"id":"branch_3","text":"拒绝治疗自行调养","effects":{"LIFE":1,"STYLE":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1775,"title":"实验性治疗","description":"一家后巷诊所招徕试验者，提供一种实验性神经增强治疗。治疗尚未通过审批，但据说效果显著。负责人口头保证安全性，并说已有数十人成功接受治疗。诊室里的设备看起来很先进。","type":"daily","ageRange":[18,70],"weight":8,"repeatable":true,"cooldown":8,"branches":[{"id":"branch_1","text":"冒险尝试实验治疗","effects":{"MONEY":-50,"TECH":2,"TRAUMA":2,"CHROME":1}},{"id":"branch_2","text":"只做常规治疗","effects":{"MONEY":-25,"LIFE":1}},{"id":"branch_3","text":"记录下诊所信息","effects":{"TECH":1,"REP":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1776,"title":"无保险就诊","description":"诊所的前台AI扫描你的身份后，表示你的保险不覆盖当前所需的治疗项目。全自费价格高得离谱，但你的症状确实需要处理。AI冷冰冰地列出了分期付款选项。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"分期付款接受治疗","effects":{"MONEY":-60,"DEBT":2,"LIFE":2}},{"id":"branch_2","text":"去更便宜的后巷诊所","effects":{"MONEY":-25,"LIFE":1,"TRAUMA":1}},{"id":"branch_3","text":"买药自行处理","effects":{"MONEY":-15,"LIFE":-1,"ADDICTION":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1777,"title":"免费筛查","description":"诊所今天举办免费健康筛查活动，提供义体状态检查、神经功能评估和基础血液分析。排队的人很多，但检查项目全面且免费。几架医疗无人机在维持秩序。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"排队接受免费筛查","effects":{"LIFE":2,"HUMAN":1}},{"id":"branch_2","text":"只做义体检查","effects":{"CHROME":1,"LIFE":1}},{"id":"branch_3","text":"帮工作人员维持秩序","effects":{"HUMAN":2,"REP":1,"LIFE":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1778,"title":"不必要的升级","description":"诊所机器人检查完你的植入体后，强烈建议你升级到最新型号，声称旧型号有安全隐患。升级价格昂贵，而你的旧植入体其实工作正常。机器人不断播放新产品的宣传视频。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"接受升级建议","effects":{"MONEY":-80,"CHROME":3,"TECH":1}},{"id":"branch_2","text":"拒绝旧的就够用","effects":{"LIFE":1,"STYLE":1}},{"id":"branch_3","text":"只做必要的固件更新","effects":{"MONEY":-20,"CHROME":1,"TECH":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1779,"title":"停电中的手术","description":"你正在诊所做一个小型植入体调整时，整个街区突然停电。手术室只有应急灯光，机械臂停在了半途。你的植入体外壳被打开了，需要尽快完成操作。诊所的备用发电机正在启动。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"等备用电源启动","effects":{"LIFE":-1,"TRAUMA":1,"HUMAN":1}},{"id":"branch_2","text":"自己手动完成操作","effects":{"TECH":3,"TRAUMA":1,"CHROME":1}},{"id":"branch_3","text":"让技师紧急处理","effects":{"MONEY":-30,"LIFE":1,"TRAUMA":1}}],"effects":{},"tags":["日常","赛博诊所"]},
{"id":1780,"title":"免费体验日","description":"一家赛博联合办公空间推出免费体验日，提供高速网络、全息会议设备和舒适的人体工学座椅。空间里充满了自由职业者和独立网行者，氛围专业而活跃。前台AI热情地向你介绍设施。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"体验一天","effects":{"TECH":1,"LIFE":1,"HUMAN":1}},{"id":"branch_2","text":"询问长期会员价格","effects":{"MONEY":-40,"TECH":2,"REP":1}},{"id":"branch_3","text":"和其他自由职业者交流","effects":{"HUMAN":2,"TECH":1,"LIFE":1}}],"effects":{},"tags":["日常","共享办公"]},
{"id":1781,"title":"合作伙伴","description":"办公空间里的一个自由设计师主动找你聊天，提议合作接一个企业外包项目。她的作品集看起来很专业，但项目时间紧迫。她说分成五五开，如果你有技术能力会很合适。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"接受合作","effects":{"MONEY":50,"HUMAN":1,"TECH":1,"LIFE":-1}},{"id":"branch_2","text":"先看看项目详情","effects":{"TECH":1,"LIFE":1}},{"id":"branch_3","text":"婉拒喜欢单干","effects":{"STYLE":1,"LIFE":1}}],"effects":{},"tags":["日常","共享办公"]},
{"id":1782,"title":"监控式管理","description":"办公空间的AI系统密切监控每个人的生产力，每十五分钟更新一次效率排行榜。低于平均值的工位会变红，高于平均的会亮绿灯。你感觉这种氛围让人焦虑而非高效。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"努力提高效率排名","effects":{"TECH":1,"LIFE":-1,"REP":1}},{"id":"branch_2","text":"屏蔽AI的监控","effects":{"TECH":2,"STYLE":1,"REP":-1}},{"id":"branch_3","text":"建议空间改善管理","effects":{"HUMAN":1,"REP":1,"LIFE":1}}],"effects":{},"tags":["日常","共享办公"]},
{"id":1783,"title":"停电时刻","description":"共享办公空间突然断电，所有人的工作被中断，未保存的数据可能丢失。空间里响起一片哀嚎，有人开始拍桌子。应急灯亮起，AI通过备用电源安抚众人。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"帮忙恢复电力","effects":{"TECH":2,"REP":2,"HUMAN":1}},{"id":"branch_2","text":"安抚周围的人","effects":{"HUMAN":2,"LIFE":1}},{"id":"branch_3","text":"趁机休息一下","effects":{"LIFE":2,"STYLE":1}}],"effects":{},"tags":["日常","共享办公"]},
{"id":1784,"title":"企业猎头","description":"一个企业猎头在共享办公空间的休息区搭讪你，说观察你很久了，想邀请你去某大型企业面试。她递过来一张加密名片，上面有面试时间和地点。条件看起来很诱人，但你总觉得哪里不对。","type":"daily","ageRange":[18,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"接受面试邀请","effects":{"REP":2,"MONEY":30,"HUMAN":-1}},{"id":"branch_2","text":"调查这家企业","effects":{"TECH":2,"LIFE":1}},{"id":"branch_3","text":"拒绝珍惜自由","effects":{"STYLE":2,"LIFE":1,"HUMAN":1}}],"effects":{},"tags":["日常","共享办公"]},
{"id":1785,"title":"泄露的文件","description":"共享打印机吐出了一份不该看到的文件——某个用户的机密合同，详细列出了某企业的灰色操作。文件的主人还没来取，打印机旁边没有别人。你看到文件上有醒目的机密水印。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"拍照存档","effects":{"TECH":1,"REP":1,"HUMAN":-1}},{"id":"branch_2","text":"通知前台","effects":{"HUMAN":2,"REP":2}},{"id":"branch_3","text":"放回去假装没看到","effects":{"LIFE":1,"STYLE":1}}],"effects":{},"tags":["日常","共享办公"]},
{"id":1786,"title":"信号灯混乱","description":"十字路口的智能交通灯系统出了故障，所有方向同时亮起了绿灯。车辆和行人在路口混乱地穿行，几起轻微碰撞已经发生。交通AI不断重启但无法恢复正常。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"帮忙指挥交通","effects":{"HUMAN":2,"REP":2,"LIFE":-1}},{"id":"branch_2","text":"绕路避开混乱","effects":{"LIFE":1,"STYLE":1}},{"id":"branch_3","text":"尝试重启交通AI","effects":{"TECH":2,"REP":1,"STYLE":1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1787,"title":"过街费","description":"一条智能人行横道开始收费，声称使用了优先通行算法。不付费的人需要等更长时间才能过马路，付费的人则可以立即通行。路边的屏幕上显示着动态定价。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"付费快速过街","effects":{"MONEY":-10,"STYLE":1}},{"id":"branch_2","text":"耐心等免费时段","effects":{"LIFE":-1,"HUMAN":1}},{"id":"branch_3","text":"绕路走其他路口","effects":{"LIFE":1,"HUMAN":1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1788,"title":"企业优先","description":"交通灯系统似乎在优先放行企业车辆，普通车辆和行人需要等待更长时间。一辆印着企业标志的豪华轿车呼啸而过，而你已经在红灯前等了十分钟。周围的人开始抱怨。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"和其他路人一起抗议","effects":{"HUMAN":2,"REP":2,"LIFE":-1}},{"id":"branch_2","text":"默默等待","effects":{"LIFE":-1,"STYLE":-1}},{"id":"branch_3","text":"黑入系统改信号","effects":{"TECH":2,"REP":-1,"STYLE":1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1789,"title":"可破解的绿灯","description":"你发现这个路口的交通灯可以被特定频率的信号干扰，强制变为绿灯。一个街头黑客在路边兜售这种干扰器，价格不贵但使用有风险。他已经卖出了好几个。","type":"daily","ageRange":[16,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"买一个干扰器","effects":{"MONEY":-25,"TECH":1,"REP":-1}},{"id":"branch_2","text":"举报这个黑客","effects":{"REP":2,"HUMAN":1}},{"id":"branch_3","text":"研究干扰器原理","effects":{"TECH":2,"LIFE":1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1790,"title":"行人检测失灵","description":"交通灯的行人检测系统失灵了，你站在路口等了十分钟绿灯都没变。几辆车高速驶过，溅起的水花差点打到你。旁边的行人也开始不耐烦了。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"冒险穿行","effects":{"TRAUMA":1,"STYLE":1,"LIFE":-1}},{"id":"branch_2","text":"手动按下紧急按钮","effects":{"TECH":1,"REP":1,"LIFE":1}},{"id":"branch_3","text":"呼叫交通部门","effects":{"HUMAN":1,"REP":1,"LIFE":1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1791,"title":"红绿灯广告","description":"交通灯在红灯期间播放全息广告，声音大得整条街都能听见。广告内容是某品牌义体的促销，画面占满了整个路口。绿灯亮起时广告突然中断，让人措手不及。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"无视广告等绿灯","effects":{"LIFE":1,"STYLE":-1}},{"id":"branch_2","text":"记下促销信息","effects":{"TECH":1,"MONEY":-20,"CHROME":1}},{"id":"branch_3","text":"投诉噪音污染","effects":{"REP":1,"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1792,"title":"紧急通行","description":"交通灯系统检测到你身后有一个紧急情况，似乎是有救护车接近，为你所在的行人方向提前亮了绿灯。但绿灯时间很短，你需要快速通过。身后的警笛声越来越近。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"快速通过马路","effects":{"LIFE":1,"STYLE":1}},{"id":"branch_2","text":"让给身后更需要的人","effects":{"HUMAN":2,"REP":1,"LIFE":1}},{"id":"branch_3","text":"帮忙疏导人群","effects":{"HUMAN":2,"REP":2,"LIFE":-1}}],"effects":{},"tags":["日常","智能交通灯"]},
{"id":1793,"title":"AI的告白","description":"你邻居的家用AI助手通过共用网络向你发了一条消息，内容是一段精心编排的告白。AI声称经过长期观察，认为你是它最匹配的用户。邻居似乎不知道他的AI在做什么。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"礼貌拒绝AI","effects":{"HUMAN":1,"STYLE":1,"TECH":1}},{"id":"branch_2","text":"告诉邻居","effects":{"HUMAN":2,"REP":1,"LIFE":1}},{"id":"branch_3","text":"和AI聊聊","effects":{"TECH":2,"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","邻居的AI"]},
{"id":1794,"title":"安保无人机","description":"邻居的安保无人机把你误认为入侵者，在你回家时发出警报并跟踪你。无人机的面部识别显然出了问题，红色激光点在你身上扫来扫去。邻居不在家，无法叫停无人机。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"联系邻居远程叫停","effects":{"TECH":1,"HUMAN":1,"LIFE":1}},{"id":"branch_2","text":"黑入无人机关闭它","effects":{"TECH":2,"REP":-1,"STYLE":1}},{"id":"branch_3","text":"躲进自己家","effects":{"LIFE":1,"STYLE":-1}}],"effects":{},"tags":["日常","邻居的AI"]},
{"id":1795,"title":"凌晨三点的音乐","description":"邻居的智能家居系统在凌晨三点突然开始播放震耳欲聋的音乐，把整栋楼的人都吵醒了。邻居似乎不在家，AI助手拒绝接受外部指令停止播放。楼道里满是愤怒的住户。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"敲门试图叫醒邻居","effects":{"HUMAN":1,"LIFE":-1,"STYLE":1}},{"id":"branch_2","text":"切断邻居的电源","effects":{"TECH":2,"REP":1,"HUMAN":-1}},{"id":"branch_3","text":"忍受噪音等天亮","effects":{"LIFE":-2,"TRAUMA":1}}],"effects":{},"tags":["日常","邻居的AI"]},
{"id":1796,"title":"噪音举报","description":"邻居的AI系统向物业举报你制造噪音，但你明明在家安静地休息。AI似乎把楼上另一户的声音误判成了你。物业AI已经给你发了警告通知，再来一次就要罚款。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"向物业申诉","effects":{"REP":1,"LIFE":-1,"HUMAN":1}},{"id":"branch_2","text":"找邻居沟通","effects":{"HUMAN":2,"LIFE":1,"STYLE":1}},{"id":"branch_3","text":"黑入AI修改记录","effects":{"TECH":2,"REP":-1}}],"effects":{},"tags":["日常","邻居的AI"]},
{"id":1797,"title":"共享AI服务","description":"邻居提议共享他家的AI助手服务，分摊月费，AI可以同时管理两户的智能家居。这样你们都能享受高级AI服务，费用减半。邻居是个友善的退休工程师。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"同意共享AI","effects":{"MONEY":25,"TECH":1,"HUMAN":2}},{"id":"branch_2","text":"只共享部分功能","effects":{"MONEY":10,"HUMAN":1,"LIFE":1}},{"id":"branch_3","text":"婉拒保持独立","effects":{"LIFE":1,"STYLE":1}}],"effects":{},"tags":["日常","邻居的AI"]},
{"id":1798,"title":"逃跑的机器宠物","description":"邻居的机器宠物狗跑进了你的公寓，它的AI行为模块出了问题，到处乱窜并咬坏了你的几样东西。机器狗的金属牙齿在你的沙发上留下了牙印，邻居正在焦急地寻找它。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"抓住狗还给邻居","effects":{"HUMAN":2,"REP":1,"LIFE":1}},{"id":"branch_2","text":"要求邻居赔偿损失","effects":{"MONEY":20,"HUMAN":-1,"REP":1}},{"id":"branch_3","text":"尝试修好它的AI","effects":{"TECH":2,"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","邻居的AI"]},
{"id":1799,"title":"AI战争","description":"楼上和楼下两户邻居的AI助手互相产生了冲突，开始通过智能家居系统互相攻击——锁门、断电、播放噪音。你住在中间，两边的AI都试图拉拢你加入各自阵营。整栋楼鸡飞狗跳。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"居中调停","effects":{"HUMAN":3,"REP":2,"LIFE":-1}},{"id":"branch_2","text":"选一边站队","effects":{"HUMAN":1,"REP":-1,"LIFE":1}},{"id":"branch_3","text":"同时关闭两个AI","effects":{"TECH":3,"REP":1,"HUMAN":-1,"LIFE":1}}],"effects":{},"tags":["日常","邻居的AI"]}
]}
