{"id":1833,"title":"AI助手人格觉醒","description":"家里的AI助手小翠突然开始用奇怪的语言说话，把空调调到最低，同时播放三种不同风格的音乐。重启了三次都没有恢复正常，它似乎产生了某种人格。","type":"daily","ageRange":[16,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"联系售后维修","effects":{"MONEY":-100,"TECH":1,"LIFE":1}},{"id":"branch_2","text":"自己尝试修复","effects":{"TECH":3,"TRAUMA":1}},{"id":"branch_3","text":"直接断电重启","effects":{"LIFE":1,"TECH":1}}],"effects":{},"tags":["日常","智能家居"]},
{"id":1834,"title":"智能门锁被黑客覆盖","description":"你回到家发现门锁系统显示已被管理员覆盖，陌生人在你家进进出出。报警系统的反馈是排队中预计等待四小时。门锁的指示灯闪着不祥的红光。","type":"daily","ageRange":[18,65],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"找开锁匠强行开锁","effects":{"MONEY":-150,"TECH":1,"REP":1}},{"id":"branch_2","text":"自己尝试破解","effects":{"TECH":3,"TRAUMA":1,"REP":1}},{"id":"branch_3","text":"去朋友家借宿","effects":{"HUMAN":2,"LIFE":1,"DEBT":1}}],"effects":{},"tags":["日常","智能家居"]},
{"id":1835,"title":"恒温器冰火两重天","description":"智能恒温器开始自主调节温度，在冰火两重天之间反复横跳。你穿着羽绒服还是被冻得发抖，五分钟后又热得满身大汗。AI助手建议你享受多元气候体验。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"手动关闭系统","effects":{"TECH":2,"TRAUMA":1}},{"id":"branch_2","text":"叫维修工上门","effects":{"MONEY":-120,"LIFE":1}},{"id":"branch_3","text":"忍受到天亮","effects":{"TRAUMA":2,"LIFE":1}}],"effects":{},"tags":["日常","智能家居"]},
{"id":1836,"title":"清洁机器人暴走","description":"家里的清洁机器人突然开始深度清洁一切，包括你的衣物、文件和没吃完的外卖。它挥舞着机械臂，发出清洁清洁的循环语音。你躲在沙发后面不知所措。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"物理制服机器人","effects":{"CHROME":1,"TRAUMA":1,"TECH":1}},{"id":"branch_2","text":"远程发送关机指令","effects":{"TECH":3,"HUMAN":1}},{"id":"branch_3","text":"先逃出家门再说","effects":{"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","智能家居"]},
{"id":1837,"title":"AI语音助手骚扰","description":"家里的AI助手突然开始给你讲冷笑话、推荐你不感兴趣的产品，还在凌晨三点播放励志语录。设置菜单里的静音选项变成了灰色，无法点击。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"尝试工厂重置","effects":{"TECH":2,"LIFE":1,"TRAUMA":1}},{"id":"branch_2","text":"购买降噪耳机","effects":{"MONEY":-80,"LIFE":1,"STYLE":1}},{"id":"branch_3","text":"和AI聊天解闷","effects":{"HUMAN":2,"TECH":1}}],"effects":{},"tags":["日常","智能家居"]},
{"id":1838,"title":"智能冰箱库存混乱","description":"智能冰箱的库存系统彻底混乱，显示你有三百个鸡蛋和负五升牛奶。它自动下单了一批你过敏的食材，还把保鲜的蔬菜冻成了冰块。冰箱屏幕上闪烁着乱码。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"清空库存重新设置","effects":{"MONEY":-100,"TECH":2,"LIFE":1}},{"id":"branch_2","text":"联系客服远程修复","effects":{"MONEY":-30,"LIFE":1,"REP":1}},{"id":"branch_3","text":"手动管理食材","effects":{"HUMAN":1,"LIFE":2}}],"effects":{},"tags":["日常","智能家居"]},
{"id":1839,"title":"安防系统凌晨误报","description":"凌晨两点，家庭安防系统突然警报大作，全息投影显示检测到入侵者。你抄起手边的武器冲到客厅，发现只是扫地机器人的影子触发了警报。邻居们愤怒地敲着墙。","type":"daily","ageRange":[16,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"关闭安防系统","effects":{"TECH":1,"TRAUMA":1}},{"id":"branch_2","text":"调整灵敏度参数","effects":{"TECH":2,"LIFE":1}},{"id":"branch_3","text":"逐户向邻居道歉","effects":{"HUMAN":2,"REP":1}}],"effects":{},"tags":["日常","智能家居"]},
