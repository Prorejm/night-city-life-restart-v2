{"events":[
{"id":1800,"title":"赛博健身房初体验","description":"街角的铁血健身推出新会员优惠，全息教练展示着义体增强训练项目。霓虹灯下，肌肉与机械交织的身影在器械间穿梭。你站在门口，感受着里面传来的汗水与机油的混合气息。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"办理年卡认真训练","effects":{"MONEY":-300,"CHROME":1,"STYLE":1}},{"id":"branch_2","text":"先体验免费课程","effects":{"TECH":1,"HUMAN":1}},{"id":"branch_3","text":"转身离开不感兴趣","effects":{"LIFE":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1801,"title":"超频训练舱挑战","description":"健身房的超频训练舱号称能激发义体潜能，但警告说有百分之三的过载风险。训练舱内，电脉冲刺激着你的神经和机械肌肉。其他训练者有的获得了突破，有的被担架抬出。","type":"daily","ageRange":[16,65],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"挑战极限模式","effects":{"CHROME":2,"TRAUMA":1,"REP":1}},{"id":"branch_2","text":"选择适度训练","effects":{"CHROME":1,"LIFE":1}},{"id":"branch_3","text":"放弃训练保平安","effects":{"HUMAN":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1802,"title":"私教课程推销","description":"一位义体增强到八成的私教拦住你，推销他的极速增肌课程。他展示着自己铬钢光泽的手臂，声称三个月能让你的力量翻倍。课程价格不菲，但效果承诺写在全息合同上。","type":"daily","ageRange":[16,60],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"购买全套课程","effects":{"MONEY":-500,"CHROME":2,"STYLE":1}},{"id":"branch_2","text":"讨价还价砍个价","effects":{"MONEY":-300,"CHROME":1,"TECH":1}},{"id":"branch_3","text":"礼貌拒绝推销","effects":{"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1803,"title":"健身房里的兄弟会","description":"训练间隙，几个常客邀请你加入他们的铁血兄弟会。他们看起来像是一群义体改装爱好者，定期聚会交流增强心得。加入他们或许能获得一些地下渠道的信息。","type":"daily","ageRange":[18,55],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"加入兄弟会","effects":{"HUMAN":2,"REP":1,"ADDICTION":1}},{"id":"branch_2","text":"礼貌拒绝保持距离","effects":{"HUMAN":1,"STYLE":1}},{"id":"branch_3","text":"只交换联系方式","effects":{"TECH":1,"HUMAN":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1804,"title":"更衣室的增强剂交易","description":"健身房更衣室的角落，有人低声兜售红色狂飙增强剂。据说能让训练效果翻倍，但副作用未知。包装上没有任何认证标识，只有一串加密二维码。","type":"daily","ageRange":[18,60],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"购买一瓶试试","effects":{"MONEY":-150,"CHROME":2,"ADDICTION":2,"TRAUMA":1}},{"id":"branch_2","text":"拒绝并向健身房举报","effects":{"REP":2,"HUMAN":1}},{"id":"branch_3","text":"拍照记录证据","effects":{"TECH":1,"REP":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1805,"title":"训练中义体过载","description":"在尝试新器械时，你的义体关节发出不祥的咔嚓声。剧痛从机械与肉体的接合处传来，训练被迫中断。健身房的医疗机器人正在扫描你的伤势，红色警告灯不停闪烁。","type":"daily","ageRange":[16,65],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"立即就医修复","effects":{"MONEY":-200,"TRAUMA":2,"LIFE":1}},{"id":"branch_2","text":"忍痛继续训练","effects":{"CHROME":1,"TRAUMA":3,"REP":1}},{"id":"branch_3","text":"休息观察几天","effects":{"TRAUMA":1,"HUMAN":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1806,"title":"铬钢杯业余健美赛","description":"健身房举办月度铬钢杯健美赛，参赛者展示着各种义体改造的肌肉线条。观众席上挤满了人，评委都是当地有名的义体改装师。冠军奖品是一套高级神经接口。","type":"daily","ageRange":[18,50],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"报名上台参赛","effects":{"STYLE":2,"REP":2,"CHROME":1,"TRAUMA":1}},{"id":"branch_2","text":"坐在观众席观看","effects":{"HUMAN":1,"TECH":1}},{"id":"branch_3","text":"帮忙组织赛事","effects":{"HUMAN":2,"REP":1}}],"effects":{},"tags":["日常","健身"]},
{"id":1807,"title":"零号厨房的机器人晚餐","description":"零号厨房是一家全自动化餐厅，从点餐到上菜全部由机器人完成。机械臂精准地翻转着汉堡，送餐机器人穿梭在餐桌间。菜单上的菜品都是AI根据营养算法生成的。","type":"daily","ageRange":[14,70],"weight":13,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"点一份招牌合成汉堡","effects":{"MONEY":-80,"LIFE":2,"TECH":1}},{"id":"branch_2","text":"选择营养优化套餐","effects":{"MONEY":-60,"LIFE":2,"HUMAN":1}},{"id":"branch_3","text":"只要一杯合成咖啡","effects":{"MONEY":-20,"TECH":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1808,"title":"合成肉异常反应","description":"用餐后你感到一阵眩晕，盘中的合成肉似乎有问题。其他几桌客人也开始出现不适症状。餐厅的机器人服务员仍在机械地微笑，似乎没有察觉任何异常。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"找经理投诉索赔","effects":{"MONEY":100,"REP":1,"HUMAN":1}},{"id":"branch_2","text":"立刻去诊所就医","effects":{"MONEY":-150,"TRAUMA":2,"LIFE":1}},{"id":"branch_3","text":"自行催吐处理","effects":{"TRAUMA":1,"LIFE":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1809,"title":"送餐机器人死机","description":"一台送餐机器人在你桌边突然死机，托盘上的合成拉面扣在了你身上。滚烫的汤汁浸透了你的衣服，机器人发出系统错误的循环提示音。周围食客纷纷侧目。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"找经理要求赔偿","effects":{"MONEY":200,"STYLE":-1,"REP":1}},{"id":"branch_2","text":"帮忙重启机器人","effects":{"TECH":2,"HUMAN":1}},{"id":"branch_3","text":"默默清理走人","effects":{"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1810,"title":"AI主厨定制料理","description":"餐厅推出AI定制料理服务，根据你的基因和口味数据生成专属菜品。主厨机器人安德烈会根据你的选择实时调整配方。价格是普通餐的三倍，但号称味觉体验无与伦比。","type":"daily","ageRange":[16,65],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"体验定制料理","effects":{"MONEY":-250,"LIFE":3,"STYLE":2}},{"id":"branch_2","text":"选择标准菜单","effects":{"MONEY":-50,"LIFE":1}},{"id":"branch_3","text":"和主厨机器人聊天","effects":{"TECH":1,"HUMAN":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1811,"title":"幸运转盘促销","description":"零号厨房推出幸运转盘活动，消费满五十信用点即可参与。奖品从免单到年度VIP卡不等。转盘在全息投影中旋转，其他食客们发出阵阵欢呼。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"消费满额参与转盘","effects":{"MONEY":-80,"STYLE":1,"HUMAN":1}},{"id":"branch_2","text":"大吃一顿碰运气","effects":{"MONEY":-120,"LIFE":2,"REP":1}},{"id":"branch_3","text":"只看不玩","effects":{"HUMAN":1,"TECH":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1812,"title":"餐厅招募人机协作专员","description":"餐厅贴出招聘启事，招募人机协作专员，说白了就是处理机器人搞不定的突发状况。时薪不高但包一顿饭。经理是一台老旧的AI，说话带着上世纪的口音。","type":"daily","ageRange":[16,55],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"应聘兼职","effects":{"MONEY":150,"HUMAN":2,"TECH":1}},{"id":"branch_2","text":"询问晋升机会","effects":{"TECH":1,"REP":1}},{"id":"branch_3","text":"不感兴趣走人","effects":{"LIFE":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1813,"title":"全息美食平台评价","description":"餐厅邀请你在全息美食平台上留下评价。好评可以帮助餐厅提升排名，差评则可能导致机器人配方调整。你的评价将影响数百名潜在顾客的选择。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"写一段走心好评","effects":{"REP":2,"HUMAN":1,"STYLE":1}},{"id":"branch_2","text":"如实评价好坏都说","effects":{"TECH":1,"REP":1,"HUMAN":1}},{"id":"branch_3","text":"匿名差评敲一笔","effects":{"MONEY":100,"REP":-1,"DEBT":1}}],"effects":{},"tags":["日常","餐厅"]},
{"id":1814,"title":"电子萌宠店参观","description":"电子萌宠宠物店里，全息投影的猫咪在空中跳跃，机器小狗摇着金属尾巴。店员介绍着各种型号的电子宠物，从基础款到带情感模拟功能的高端款应有尽有。","type":"daily","ageRange":[10,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"购买基础款电子猫","effects":{"MONEY":-300,"HUMAN":2,"LIFE":1}},{"id":"branch_2","text":"选购高端情感款","effects":{"MONEY":-800,"HUMAN":3,"LIFE":2,"TECH":1}},{"id":"branch_3","text":"只是看看不买","effects":{"HUMAN":1}}],"effects":{},"tags":["日常","宠物"]},
{"id":1815,"title":"电子宠物系统故障","description":"你的电子宠物突然开始重复同一句话，眼睛闪烁着错误代码。它拒绝执行任何指令，偶尔发出刺耳的噪音。宠物店的保修期刚过三天。","type":"daily","ageRange":[10,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"送回店里维修","effects":{"MONEY":-120,"TECH":1,"HUMAN":1}},{"id":"branch_2","text":"自己动手修理","effects":{"TECH":2,"HUMAN":1}},{"id":"branch_3","text":"直接换个新的","effects":{"MONEY":-300,"LIFE":1}}],"effects":{},"tags":["日常","宠物"]},
{"id":1816,"title":"赛博宠物美容服务","description":"宠物店推出赛博美容服务，为电子宠物更换外壳、升级LED表情包。等候区里，几个主人正讨论着给宠物加装全息投影模块的事。","type":"daily","ageRange":[10,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"给宠物做美容升级","effects":{"MONEY":-100,"STYLE":2,"HUMAN":1}},{"id":"branch_2","text":"只做基础保养","effects":{"MONEY":-40,"HUMAN":1}},{"id":"branch_3","text":"自己动手改装","effects":{"TECH":2,"STYLE":1}}],"effects":{},"tags":["日常","宠物"]},
{"id":1817,"title":"智能行为训练课程","description":"宠物店开设智能行为训练课程，教电子宠物学习新技能。课程包括语音指令响应、情感模拟升级和社交行为优化。训练师是一台经过特殊编程的AI。","type":"daily","ageRange":[10,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"报名正式训练课","effects":{"MONEY":-200,"TECH":2,"HUMAN":2}},{"id":"branch_2","text":"购买训练手册自学","effects":{"MONEY":-30,"TECH":1}},{"id":"branch_3","text":"在家自己摸索","effects":{"TECH":1,"HUMAN":1,"LIFE":1}}],"effects":{},"tags":["日常","宠物"]},
{"id":1818,"title":"电子宠物才艺大赛","description":"宠物店举办季度才艺大赛，各路电子宠物展示着花式技能。有的会全息投影，有的能识别情绪并安慰主人。冠军奖品是终身免费保养服务。","type":"daily","ageRange":[10,70],"weight":8,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"带着宠物报名参赛","effects":{"STYLE":2,"REP":2,"HUMAN":1}},{"id":"branch_2","text":"坐在观众席观看","effects":{"HUMAN":2,"TECH":1}},{"id":"branch_3","text":"申请做评委","effects":{"REP":1,"TECH":1,"HUMAN":1}}],"effects":{},"tags":["日常","宠物"]},
{"id":1819,"title":"电子宠物年度体检","description":"电子宠物的年度体检到了，需要检查电池衰减、处理器性能和情感模块状态。技师说你的宠物处理器有些过热，建议升级散热系统。","type":"daily","ageRange":[10,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"做全面体检和升级","effects":{"MONEY":-250,"TECH":1,"HUMAN":2}},{"id":"branch_2","text":"只做基础检查","effects":{"MONEY":-80,"HUMAN":1}},{"id":"branch_3","text":"跳过体检省钱","effects":{"LIFE":1,"HUMAN":-1}}],"effects":{},"tags":["日常","宠物"]},
{"id":1820,"title":"像素之魂数字艺术展","description":"像素之魂数字艺术展在市中心开幕，全息投影的NFT作品漂浮在展厅各处。每一件作品都记录在区块链上，价格从几百到几百万信用点不等。策展人是一位从不露面的虚拟艺术家。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"购票入场参观","effects":{"MONEY":-50,"STYLE":3,"TECH":1}},{"id":"branch_2","text":"等周末免费日再去","effects":{"STYLE":2,"HUMAN":1}},{"id":"branch_3","text":"线上虚拟参观","effects":{"TECH":1,"STYLE":1}}],"effects":{},"tags":["日常","艺术"]},
{"id":1821,"title":"NFT限量作品拍卖","description":"展览附设小型拍卖会，几件限量NFT作品即将开拍。拍卖师是全息投影的AI，竞价者来自全球各地。一件霓虹城日落的数字画作起拍价就已经超出你的预算。","type":"daily","ageRange":[18,65],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"举牌参与竞拍","effects":{"MONEY":-500,"STYLE":3,"REP":2}},{"id":"branch_2","text":"坐在后排观摩学习","effects":{"TECH":1,"STYLE":2}},{"id":"branch_3","text":"试图低价捡漏","effects":{"MONEY":-100,"STYLE":1,"DEBT":1}}],"effects":{},"tags":["日常","艺术"]},
{"id":1822,"title":"铬色幻影签名会","description":"知名数字艺术家铬色幻影在展览现场举办签名会。ta从不以真面目示人，全程通过全息投影与粉丝互动。队伍已经排到了展厅外面。","type":"daily","ageRange":[14,60],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"排队等候签名","effects":{"STYLE":2,"HUMAN":2,"REP":1}},{"id":"branch_2","text":"购买限量周边","effects":{"MONEY":-150,"STYLE":2,"REP":1}},{"id":"branch_3","text":"在旁边偷偷拍照","effects":{"TECH":1,"REP":-1}}],"effects":{},"tags":["日常","艺术"]},
{"id":1823,"title":"互动创作区体验","description":"展览设有互动创作区，参观者可以使用专业软件创作自己的数字艺术作品。优秀作品有机会被收录进展览的社区展区。创作工具包括AI辅助绘画和3D雕塑系统。","type":"daily","ageRange":[12,65],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"认真创作一件作品","effects":{"STYLE":3,"TECH":1,"REP":1}},{"id":"branch_2","text":"随便玩玩试试","effects":{"STYLE":1,"HUMAN":1}},{"id":"branch_3","text":"学习他人作品","effects":{"TECH":2,"STYLE":1}}],"effects":{},"tags":["日常","艺术"]},
{"id":1824,"title":"NFT投资咨询","description":"展览的投资顾问提供NFT投资咨询服务，分析各作品升值潜力。ta展示着几张过去涨幅惊人的作品曲线图，暗示现在正是入场的最佳时机。","type":"daily","ageRange":[18,65],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"投资一件潜力作品","effects":{"MONEY":-600,"STYLE":2,"DEBT":1}},{"id":"branch_2","text":"只听咨询不投资","effects":{"TECH":2,"STYLE":1}},{"id":"branch_3","text":"质疑投资风险","effects":{"TECH":1,"REP":1}}],"effects":{},"tags":["日常","艺术"]},
{"id":1825,"title":"社区作品评奖投票","description":"展览最后一天，参观者可以投票选出最佳社区作品。入围作品在全息屏幕上轮播展示，每件都有独特的赛博朋克美学风格。你的票将决定最终归属。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"认真欣赏后投票","effects":{"REP":2,"STYLE":1,"HUMAN":1}},{"id":"branch_2","text":"随便投一票应付","effects":{"HUMAN":1}},{"id":"branch_3","text":"帮朋友拉票","effects":{"HUMAN":1,"REP":1,"STYLE":1}}],"effects":{},"tags":["日常","艺术"]},
{"id":1826,"title":"赛博周末市集淘宝","description":"赛博周末市集在废弃停车场开张，霓虹灯照亮了密密麻麻的摊位。从二手义体零件到自制合成食品，从盗版芯片到古董电子设备，这里应有尽有。空气中弥漫着烤肉和电子焊锡的味道。","type":"daily","ageRange":[14,70],"weight":13,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"仔细逛逛淘淘宝","effects":{"MONEY":-100,"TECH":2,"STYLE":1}},{"id":"branch_2","text":"随便逛逛凑热闹","effects":{"HUMAN":2,"STYLE":1}},{"id":"branch_3","text":"摆摊卖点旧物","effects":{"MONEY":80,"HUMAN":1}}],"effects":{},"tags":["日常","市集"]},
{"id":1827,"title":"市集深处的黑市交易","description":"市集深处有人招呼你过去，展示着几件来路不明的特殊商品。包括军用级芯片、未注册的义体组件和一些看不懂的生化药剂。价格远低于正规渠道，但风险同样很高。","type":"daily","ageRange":[18,60],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"购买军用级芯片","effects":{"MONEY":-200,"TECH":3,"DEBT":1}},{"id":"branch_2","text":"买未注册义体组件","effects":{"MONEY":-300,"CHROME":2,"TRAUMA":1}},{"id":"branch_3","text":"拒绝交易离开","effects":{"REP":2,"HUMAN":1}}],"effects":{},"tags":["日常","市集"]},
