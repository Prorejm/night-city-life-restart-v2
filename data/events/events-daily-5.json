{"id":1963,"title":"加密彩票购买","description":"街角的数字彩票终端滚动着巨额奖池数字，全息投影显示上一期无人中奖，奖金累积到了惊人的数目。AI语音热情地介绍着各种玩法和概率。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"买一张随机号码彩票","effects":{"MONEY":-20,"LIFE":1,"ADDICTION":1}},{"id":"branch_2","text":"买一组自选号码","effects":{"MONEY":-50,"ADDICTION":1}},{"id":"branch_3","text":"只看不买","effects":{"LIFE":1}}],"effects":{},"tags":["日常","彩票"]},
