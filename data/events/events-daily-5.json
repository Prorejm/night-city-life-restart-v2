{"events":[
{"id":1900,"title":"赛博自助洗衣店","description":"街角的赛博自助洗衣店刚刚翻新，全息广告牌上滚动着纳米清洁三分钟搞定的标语。投币口已被替换为虹膜扫描支付，洗衣机嗡嗡作响中散发着臭氧和合成薰衣草的味道。几个流浪汉正缩在角落利用烘干机的余温取暖。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"使用纳米清洗服务","effects":{"MONEY":-80,"STYLE":2}},{"id":"branch_2","text":"帮流浪汉付一次洗衣费","effects":{"MONEY":-120,"HUMAN":3,"REP":1}},{"id":"branch_3","text":"蹭烘干机余温取暖省点钱","effects":{"MONEY":20,"LIFE":-1}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1901,"title":"洗衣机故障警报","description":"你把衣服塞进洗衣机，扫描付款后机器突然发出刺耳的警报声。控制面板上红光闪烁，显示纳米机器人校准失败请联系技术人员。你的衣服被锁在滚筒里，机器拒绝打开舱门。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"付费请维修工来修","effects":{"MONEY":-100,"TECH":1}},{"id":"branch_2","text":"黑入机器控制系统强行开锁","effects":{"TECH":2,"TRAUMA":1}},{"id":"branch_3","text":"联系客服投诉索赔","effects":{"MONEY":50,"REP":1}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1902,"title":"洗衣店里的神秘交易","description":"洗衣店里有个穿长风衣的家伙一直在角落徘徊，时不时打量四周。你注意到他从洗衣机里取出的不是衣服，而是一个密封的金属盒子。他发现你在看他，朝你点了点头。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"假装没看见继续洗衣服","effects":{"LIFE":1}},{"id":"branch_2","text":"上前搭话询问盒子的事","effects":{"REP":1,"TRAUMA":1}},{"id":"branch_3","text":"拍下照片发给信息贩子","effects":{"TECH":1,"MONEY":30,"REP":-1}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1903,"title":"洗衣会员推广","description":"洗衣店的AI推销员拦住了你，热情推介最新会员套餐。尊享会员每月只需一百九十九信用点，享受纳米深度清洁和紫外线杀菌三重服务。全息投影展示着闪亮如新的衣物效果。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"办理年度会员","effects":{"MONEY":-400,"STYLE":3}},{"id":"branch_2","text":"办理月度会员","effects":{"MONEY":-199,"STYLE":1}},{"id":"branch_3","text":"拒绝推销用免费档","effects":{"MONEY":-30}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1904,"title":"洗衣店偶遇旧友","description":"你在等衣服洗完时，旁边机器前转过一张熟悉的面孔。是你以前街头混日子的老搭档，对方看起来混得不错，义体手臂闪着铬合金光泽。嘿好久不见，你还是老样子啊。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"请对方喝杯合成咖啡叙旧","effects":{"MONEY":-20,"HUMAN":3,"REP":1}},{"id":"branch_2","text":"借机推销自己的小生意","effects":{"REP":2,"MONEY":50}},{"id":"branch_3","text":"点头打个招呼就离开","effects":{"LIFE":1}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1905,"title":"衣物被纳米机器人损坏","description":"取出洗好的衣服时，你发现最喜欢的夹克被纳米机器人过度清洁，面料出现了明显的腐蚀痕迹。洗衣店贴着衣物损坏概不负责的电子告示，但旁边的投诉终端似乎还能用。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"向店方正式投诉索赔","effects":{"MONEY":100,"REP":1}},{"id":"branch_2","text":"找地下裁缝修补衣服","effects":{"MONEY":-60,"STYLE":2}},{"id":"branch_3","text":"自学纳米修补技术自己修","effects":{"TECH":2,"STYLE":1}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1906,"title":"深夜洗衣店的常客","description":"凌晨三点，二十四小时赛博洗衣店只有你和另外一个顾客。那人戴着老旧的AR眼镜，一边等衣服一边低声自语，像在跟看不见的人对话。烘干机有节奏地转动，霓虹灯光透过雾化的玻璃投射出诡异的光影。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"安静地等自己的衣服","effects":{"LIFE":1,"TRAUMA":-1}},{"id":"branch_2","text":"和深夜常客聊几句","effects":{"HUMAN":2,"LIFE":1}},{"id":"branch_3","text":"调高烘干温度快速烘干","effects":{"MONEY":-10,"STYLE":1}}],"effects":{},"tags":["日常","洗衣"]},
{"id":1907,"title":"无人机包裹投递","description":"自动化邮局的无人机蜂巢前排着长队，每个人都在等自己的包裹。嗡嗡声震耳欲聋，六旋翼无人机像蜂群一样从顶部出口鱼贯而出。你的包裹显示投递异常需到柜台确认。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"排队去柜台确认取件","effects":{"MONEY":-5,"LIFE":1}},{"id":"branch_2","text":"付加急费让无人机优先派送","effects":{"MONEY":-50,"TECH":1}},{"id":"branch_3","text":"放弃取件改天再来","effects":{"LIFE":-1}}],"effects":{},"tags":["日常","邮局"]},
{"id":1908,"title":"邮寄包裹被扫描异常","description":"你在自动化邮局寄包裹时，X光扫描仪突然亮起红灯。机械臂将你的包裹扣下，AI语音冰冷地宣布检测到可疑物品已通知执法部门。周围的人纷纷侧目，你有三十秒做出反应。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"声称是误报要求人工复核","effects":{"REP":1,"TRAUMA":1}},{"id":"branch_2","text":"趁混乱强行拿回包裹跑路","effects":{"TRAUMA":2,"REP":-2}},{"id":"branch_3","text":"配合检查接受处理","effects":{"MONEY":-200,"REP":-1}}],"effects":{},"tags":["日常","邮局"]},
{"id":1909,"title":"量子加密快递服务","description":"邮局新推出了量子加密快递服务，号称包裹可以在两小时内通过地下管道网络送达全城任何地点。全息广告展示着光滑的管道和高速穿梭的货舱，首单半价。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"体验量子加密快递","effects":{"MONEY":-60,"TECH":2}},{"id":"branch_2","text":"用普通无人机邮寄","effects":{"MONEY":-20}},{"id":"branch_3","text":"询问有没有更便宜的选项","effects":{"MONEY":-5,"TECH":1}}],"effects":{},"tags":["日常","邮局"]},
{"id":1910,"title":"帮邻居代收包裹","description":"楼下自动化邮箱弹出提示，你邻居的包裹被误投到了你的信箱。包裹上贴着易碎全息设备的标签，寄件地址是某个你从没听过的公司。邻居的终端一直联系不上。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"妥善保管等邻居来取","effects":{"HUMAN":2,"REP":1}},{"id":"branch_2","text":"好奇地扫描看看里面是什么","effects":{"TECH":1,"REP":-1}},{"id":"branch_3","text":"退回邮局重新投递","effects":{"MONEY":-10,"HUMAN":1}}],"effects":{},"tags":["日常","邮局"]},
{"id":1911,"title":"无人机投递事故","description":"一架送货无人机在你面前突然失控，螺旋桨打在电线上了，包裹从十米高空坠落砸在人行道上。四旋翼发出最后的嗡鸣后冒烟坠毁，散落的零件和货物碎了一地。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"帮忙捡拾散落货物并上报","effects":{"HUMAN":3,"REP":2}},{"id":"branch_2","text":"趁乱捡走一些值钱的零件","effects":{"MONEY":80,"REP":-2}},{"id":"branch_3","text":"拍下事故视频卖给新闻站","effects":{"MONEY":40,"TECH":1}}],"effects":{},"tags":["日常","邮局"]},
{"id":1912,"title":"邮寄手写信件","description":"在这个一切数字化的年代，你竟然想寄一封手写信。邮局AI看到纸质信封时停顿了整整三秒，才从数据库里调出纸质邮件处理流程。柜台的激光印章在信封上烙下荧光邮戳。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"寄出这封特别的信","effects":{"MONEY":-30,"HUMAN":3,"LIFE":2}},{"id":"branch_2","text":"改用数字方式发送","effects":{"MONEY":-5}},{"id":"branch_3","text":"寄挂号信确保送达","effects":{"MONEY":-50,"HUMAN":2}}],"effects":{},"tags":["日常","邮局"]},
{"id":1913,"title":"邮局入口身份扫描","description":"走进邮局时，入口的生物识别门突然发出警报。显示屏上出现一张模糊的通缉照片，和你有三分相似。安保机器人缓缓转向你，机械臂上的扫描仪红光闪烁。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"主动配合身份核实","effects":{"REP":1,"TRAUMA":1,"LIFE":-1}},{"id":"branch_2","text":"慌张地转身离开","effects":{"TRAUMA":2,"REP":-1}},{"id":"branch_3","text":"冷静解释并出示ID","effects":{"REP":2,"LIFE":1}}],"effects":{},"tags":["日常","邮局"]},
{"id":1914,"title":"全息摄影棚体验","description":"赛博摄影工作室推出了全息记忆照片服务，能够捕捉三维光影瞬间。摄影师是一台装有美学芯片的机械臂，墙上挂满了全息样片，人物仿佛要从照片中走出来。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"拍摄一组全息写真","effects":{"MONEY":-150,"STYLE":3,"HUMAN":1}},{"id":"branch_2","text":"只拍一张全息头像","effects":{"MONEY":-50,"STYLE":2}},{"id":"branch_3","text":"请教摄影技巧","effects":{"TECH":2,"STYLE":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1915,"title":"街头赛博风景抓拍","description":"你走在霓虹灯闪烁的街头，雨后的积水倒映着层层叠叠的全息广告。一架飞行车掠过低空，尾焰在夜空中划出一道光线。这画面太赛博了，你下意识举起手机。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"用专业模式拍下这幕","effects":{"STYLE":2,"TECH":1}},{"id":"branch_2","text":"开启全息录制完整场景","effects":{"TECH":2,"STYLE":1}},{"id":"branch_3","text":"发到社交媒体上分享","effects":{"REP":2,"STYLE":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1916,"title":"全息老照片修复","description":"你在抽屉里翻出一张泛黄的老照片，是祖父年轻时的模样。赛博修复店声称能用AI重建全息影像，让照片中的人重新立体起来。店主展示着修复前后的对比效果。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"花重金修复老照片","effects":{"MONEY":-200,"HUMAN":3,"LIFE":2}},{"id":"branch_2","text":"只做基础数字化修复","effects":{"MONEY":-50,"HUMAN":1}},{"id":"branch_3","text":"用手机APP自己尝试修复","effects":{"TECH":2,"HUMAN":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1917,"title":"赛博摄影大赛报名","description":"霓虹城年度赛博摄影大赛正在报名，主题是城市中的光与影。一等奖是一台专业级全息相机，评审团里有几位知名赛博艺术家。你的朋友们都鼓励你参加。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"认真准备作品参赛","effects":{"STYLE":3,"REP":2,"TECH":1}},{"id":"branch_2","text":"随便交一张应付","effects":{"STYLE":1,"HUMAN":1}},{"id":"branch_3","text":"去当志愿者帮忙组织","effects":{"HUMAN":2,"REP":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1918,"title":"暗房里的秘密冲洗","description":"一家地下暗房提供老式胶片冲洗服务，据说有些客户在这里冲洗不该被看到的照片。暗房里弥漫着显影液的气味，红色安全灯下，老板神秘地打量着你。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"冲洗一卷自己的胶片","effects":{"MONEY":-40,"STYLE":2,"TECH":1}},{"id":"branch_2","text":"帮老板干点活换免费冲洗","effects":{"HUMAN":2,"TECH":1,"MONEY":30}},{"id":"branch_3","text":"帮老板传递一个密封信封","effects":{"MONEY":80,"REP":-1,"DEBT":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1919,"title":"全息自拍打印机","description":"街边新装了一台全息自拍打印机，扫码就能把自拍打印成三维全息卡片。机器上展示着各种滤镜效果，从复古胶片风到赛博朋克霓虹风应有尽有。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"打印一组全息自拍","effects":{"MONEY":-30,"STYLE":2,"HUMAN":1}},{"id":"branch_2","text":"打印送给朋友当礼物","effects":{"MONEY":-30,"HUMAN":3,"REP":1}},{"id":"branch_3","text":"研究打印机的技术原理","effects":{"TECH":2,"STYLE":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1920,"title":"摄影器材黑市淘宝","description":"摄影器材黑市里堆满了来路不明的镜头和传感器，有些明显是从军用无人机上拆下来的。摊主是个独眼的老摄影师，义眼里装着精密测光仪。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"购买一个军用级全息镜头","effects":{"MONEY":-300,"TECH":3,"DEBT":1}},{"id":"branch_2","text":"买一个二手民用镜头","effects":{"MONEY":-80,"TECH":2}},{"id":"branch_3","text":"和老板聊聊器材知识","effects":{"TECH":2,"HUMAN":1}}],"effects":{},"tags":["日常","摄影"]},
{"id":1921,"title":"智能镜子早晨建议","description":"早晨醒来，浴室的智能镜子自动亮起，扫描你的面部后弹出今日形象建议。根据你的日程安排，AI推荐了一套干练的商务赛博风搭配，还标注了每件衣物的存放位置。","type":"daily","ageRange":[14,70],"weight":12,"repeatable":true,"cooldown":3,"branches":[{"id":"branch_1","text":"采纳AI的搭配建议","effects":{"STYLE":2,"TECH":1}},{"id":"branch_2","text":"无视建议自己搭配","effects":{"STYLE":1,"HUMAN":1}},{"id":"branch_3","text":"让AI推荐更张扬的风格","effects":{"STYLE":3,"REP":1}}],"effects":{},"tags":["日常","智能镜子"]},
{"id":1922,"title":"镜子推送健康警告","description":"智能镜子在晨间扫描后弹出红色警告，显示你的皮肤水分含量偏低且眼压略高。建议栏列出了推荐的合成补剂和附近诊所的预约链接，全息图表展示着你的健康趋势。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"购买推荐的合成补剂","effects":{"MONEY":-80,"LIFE":2,"HUMAN":1}},{"id":"branch_2","text":"预约诊所做个检查","effects":{"MONEY":-150,"LIFE":3}},{"id":"branch_3","text":"关掉警告不放在心上","effects":{"LIFE":-1,"TRAUMA":1}}],"effects":{},"tags":["日常","智能镜子"]},
{"id":1923,"title":"镜子软件系统更新","description":"智能镜子提示有新的系统更新可用，号称优化了面部识别精度和穿搭推荐算法。更新日志还提到了新增的虚拟试衣功能，但需要额外的存储空间。","type":"daily","ageRange":[14,70],"weight":11,"repeatable":true,"cooldown":4,"branches":[{"id":"branch_1","text":"立即更新系统","effects":{"TECH":2,"STYLE":1}},{"id":"branch_2","text":"等一段时间再说","effects":{"LIFE":1}},{"id":"branch_3","text":"尝试破解高级功能","effects":{"TECH":3,"TRAUMA":1}}],"effects":{},"tags":["日常","智能镜子"]},
{"id":1924,"title":"虚拟试衣功能体验","description":"镜子新更新的虚拟试衣功能让你可以在屏幕里换上任何衣服，全息投影实时渲染上身效果。内置商城的推荐算法精准得令人不安，你还没搜就弹出了你正想要的款式。","type":"daily","ageRange":[14,70],"weight":10,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"下单购买试穿满意的衣服","effects":{"MONEY":-200,"STYLE":3}},{"id":"branch_2","text":"只试不买截图存档","effects":{"STYLE":1,"TECH":1}},{"id":"branch_3","text":"试用各种奇装异服解闷","effects":{"HUMAN":2,"STYLE":1}}],"effects":{},"tags":["日常","智能镜子"]},
{"id":1925,"title":"镜子数据泄露通知","description":"智能镜子品牌发来紧急通知，称服务器被黑客攻击，用户面部数据和穿搭记录可能泄露。你的镜子上弹出橙色警告框，建议立即更改密码并启用双重认证。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"立即更改密码加强安全","effects":{"TECH":2,"REP":1}},{"id":"branch_2","text":"投诉品牌要求赔偿","effects":{"MONEY":100,"REP":1}},{"id":"branch_3","text":"不在乎继续使用","effects":{"TRAUMA":1,"REP":-1}}],"effects":{},"tags":["日常","智能镜子"]},
{"id":1926,"title":"镜子AI心理评估","description":"智能镜子的最新功能可以根据面部微表情进行心理评估，它扫描完毕后建议你今天多与人交流。评估报告显示你的压力指数偏高，社交意愿偏低。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":5,"branches":[{"id":"branch_1","text":"采纳建议主动找人聊天","effects":{"HUMAN":3,"LIFE":2}},{"id":"branch_2","text":"关闭这个功能嫌烦","effects":{"LIFE":1}},{"id":"branch_3","text":"查看详细评估报告","effects":{"TECH":1,"HUMAN":1,"TRAUMA":1}}],"effects":{},"tags":["日常","智能镜子"]},
