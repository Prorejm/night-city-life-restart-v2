{"id":1959,"title":"车辆检测发现隐患","description":"你请第三方检测机构对中意的飞行车做全面检测，技师在反重力引擎舱内发现了非原厂改装的痕迹。检测报告显示引擎核心有过过热记录，卖家可能隐瞒了事故史。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"拿着报告要求降价","effects":{"MONEY":300,"REP":2}},{"id":"branch_2","text":"放弃这辆另找别的","effects":{"LIFE":1,"TECH":1}},{"id":"branch_3","text":"买下来自己修","effects":{"MONEY":-200,"TECH":3,"TRAUMA":1}}],"effects":{},"tags":["日常","二手车"]},
{"id":1960,"title":"飞行车拍卖会","description":"城市扣押飞行车拍卖会在地下停车场举行，数十辆来路不明的飞行车整齐排列。拍卖师是全息AI，起拍价低得惊人但车辆状况不明。空气中弥漫着紧张和兴奋。","type":"daily","ageRange":[14,70],"weight":9,"repeatable":true,"cooldown":6,"branches":[{"id":"branch_1","text":"竞拍一辆低价车碰运气","effects":{"MONEY":-300,"DEBT":1,"STYLE":1}},{"id":"branch_2","text":"只观察不举牌","effects":{"TECH":1,"LIFE":1}},{"id":"branch_3","text":"和旁边的行家交流情报","effects":{"HUMAN":2,"TECH":2,"REP":1}}],"effects":{},"tags":["日常","二手车"]},
{"id":1961,"title":"二手车交易陷阱","description":"你通过暗网联系到一个卖家，飞行车价格低得离谱。见面地点在废弃仓库，卖家戴着面具只露出一双义眼。车辆看起来完好但文件信息对不上。","type":"daily","ageRange":[14,70],"weight":8,"repeatable":true,"cooldown":7,"branches":[{"id":"branch_1","text":"冒险买下低价车","effects":{"MONEY":-150,"DEBT":2,"REP":-2}},{"id":"branch_2","text":"要求验证车辆合法性","effects":{"REP":2,"TRAUMA":1}},{"id":"branch_3","text":"感觉不对果断离开","effects":{"LIFE":2,"REP":1}}],"effects":{},"tags":["日常","二手车"]},
