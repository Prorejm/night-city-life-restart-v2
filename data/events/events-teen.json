        { "id": "branch_2", "text": "拒绝，不想卷入情报世界的危险", "effects": { "COOL": 2 } }
      ],
      "effects": { "STREET_SMART": 2, "MONEY": 200 },
      "tags": ["青年", "情报", "蜘蛛", "地下"],
      "deathChainEntry": false
